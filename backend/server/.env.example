# 复制为 .env 后按需修改（.env 已被 gitignore）
DATABASE_URL=postgres://spark:spark_dev_2026@127.0.0.1:5433/spark_alliance?sslmode=disable
JWT_SECRET=dev_secret_change_me_2026
PORT=8787
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180,http://localhost:5181,http://127.0.0.1:5181
ADMIN_INIT_PASSWORD=SparkAdmin2026!

# ===== v2 可选配置 =====
# AES-GCM 主密钥（AI 供应商 api_key 加密存库）；缺省用 JWT_SECRET 派生
# SECRET_KEY=

# SMTP 五项齐全才真发邮件，否则验证码走 dev_mode 明文返回
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# 沙箱支付回调 HMAC 密钥（默认 dev 值）
SANDBOX_PAY_SECRET=sandbox_pay_dev_secret_2026

# 支付宝当面付（三项齐全即激活，否则 alipay 支付返回 503 PROVIDER_UNCONFIGURED）
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
# ALIPAY_NOTIFY_URL=

# AI 供应商 seed（首启表空时自动导入为第一条）
# AI_BASE_URL=http://127.0.0.1:8080/v1
# AI_API_KEY=
# AI_MODEL=gpt-4o-mini
