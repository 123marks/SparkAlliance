  "environmentVariables": {
    "required": [
      {
        "name": "GITHUB_TOKEN",
        "description": "GitHub个人访问令牌",
        "getFrom": "https://github.com/settings/tokens",
        "permissions": ["repo", "issues", "pull_requests"]
      },
      {
        "name": "BRAVE_API_KEY",
        "description": "Brave搜索API密钥",
        "getFrom": "https://brave.com/search/api/",
        "freeQuota": "2000次/月"
      }
    ],
    "optional": [
      {
        "name": "DATABASE_URL",
        "description": "PostgreSQL数据库连接字符串",
        "stage": "阶段四"
      },
      {
        "name": "REDIS_URL",
        "description": "Redis连接字符串",
        "stage": "阶段四"
      },
      {
        "name": "STRIPE_API_KEY",
        "description": "Stripe API密钥",
        "stage": "阶段四"
      }
    ]
  },
  
  "testingCommands": {
    "inspector": "mcp-inspector",
    "filesystem": "mcp-inspector npx -y @modelcontextprotocol/server-filesystem C:\\Users\\whw\\Desktop\\Spark-Alliance",
