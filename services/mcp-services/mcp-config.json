{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\whw\\Desktop\\Spark-Alliance"
      ],
      "description": "文件系统操作 - 读写项目文件",
      "enabled": true
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub集成 - 仓库管理、Issues、PR",
      "enabled": true,
      "required": true,
      "setupInstructions": "需要设置GITHUB_TOKEN环境变量，访问 https://github.com/settings/tokens 创建"
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      },
      "description": "Brave搜索 - 网络搜索功能",
      "enabled": true,
      "required": false,
      "setupInstructions": "需要设置BRAVE_API_KEY环境变量，访问 https://brave.com/search/api/ 获取"
    }
  },
  
  "futureMcpServers": {
    "postgres": {
      "package": "@modelcontextprotocol/server-postgres",
      "description": "PostgreSQL数据库 - 生产环境数据存储",
      "priority": "high",
      "stage": "阶段四：电商功能开发",
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    },
